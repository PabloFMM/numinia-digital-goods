# GitHub Repository Configuration
GITHUB_REPO_OWNER=PabloFMM
GITHUB_REPO_NAME=numinia-digital-goods-data
GITHUB_BRANCH=main

# GitHub Token — USE FINE-GRAINED TOKEN (not Classic)
# Settings > Developer settings > Personal access tokens > Fine-grained tokens
# Repository: numinia-digital-goods-data ONLY
# Permissions: Contents → Read and write (nothing else)
# DO NOT use Classic tokens with full `repo` scope
GITHUB_TOKEN=

# GitHub OAuth App (optional — only for user login, not needed for gallery)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Session Signing (HMAC-SHA256) — REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Admin Wallet Auth (SIWE)
# Comma-separated Ethereum addresses allowed to access /en/admin
ADMIN_WALLET_ADDRESSES=0x42e62e421bEdf2469826879Ec1a0574d7D3ccA26

# Cloudflare R2 Storage (optional — falls back to GitHub for uploads <3.5MB)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=numinia-assets
R2_PUBLIC_URL=

# Stripe (optional — season pass checkout)
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public URLs
NEXT_PUBLIC_SITE_URL=https://numinia.store
NEXT_PUBLIC_OPEN_SOURCE_3D_ASSETS_RAW_BASE=
NEXT_PUBLIC_POLYGON_MODELS_RAW_BASE=
